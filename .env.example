# FamilyMeal Planner - Baserow Integration
# Kopiere zu .env.local und trage echte Werte ein

# Baserow Configuration
NEXT_PUBLIC_BASEROW_URL=https://api.baserow.io
NEXT_PUBLIC_BASEROW_TOKEN=your_baserow_api_token_here

# Database & Tables (wird nach Setup gesetzt)
NEXT_PUBLIC_BASEROW_DATABASE_ID=your_database_id
NEXT_PUBLIC_BASEROW_RECIPES_TABLE_ID=your_recipes_table_id
NEXT_PUBLIC_BASEROW_PREFERENCES_TABLE_ID=your_preferences_table_id
NEXT_PUBLIC_BASEROW_WEEK_PLANS_TABLE_ID=your_week_plans_table_id
NEXT_PUBLIC_BASEROW_SHOPPING_TABLE_ID=your_shopping_table_id

# Development Settings
NEXT_PUBLIC_ENABLE_BASEROW=true
NEXT_PUBLIC_CACHE_TTL=300000
NEXT_PUBLIC_BATCH_SIZE=100

# For debugging
NEXT_PUBLIC_DEBUG_BASEROW=false